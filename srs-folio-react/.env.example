# Environment Variables Example
# Copy this file to .env for local development
# Add your environment variables to Vercel dashboard for production

# Formspree Endpoint (if you want to make it configurable)
# VITE_FORMSPREE_ENDPOINT=your_endpoint_here

# API Keys (if needed in the future)
# VITE_API_KEY=your_api_key_here

# Note: All Vite environment variables must start with VITE_
# They will be exposed to the client-side code
